<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 11 and below (API 30-) full backup content rules for Kilo.

    Policy: back up user workout/weight data (stored in WebView localStorage);
    exclude SharedPreferences which contain Capacitor framework internals
    (device IDs, cached paths) that do not restore cleanly across devices.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
</full-backup-content>
