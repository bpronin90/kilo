<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31+) backup policy for Kilo.

    Policy: back up user workout/weight data (stored in WebView localStorage);
    exclude SharedPreferences which contain Capacitor framework internals
    (device IDs, cached paths) that do not restore cleanly across devices.
    Applies to both cloud backup and device-to-device transfer.
-->
<data-extraction-rules xmlns:android="http://schemas.android.com/apk/res/android">
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
