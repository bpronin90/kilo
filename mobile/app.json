{
  "expo": {
    "name": "Kilo",
    "slug": "kilo-native",
    "version": "0.49.9",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4efe5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.benpronin.kilo"
    },
    "android": {
      "package": "com.benpronin.kilo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4efe5"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/60e052a9-629b-4e48-ae58-52642e951c9c",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD",
      "codeSigningCertificate": "./certs/certificate.crt",
      "codeSigningMetadata": {
        "keyid": "main",
        "alg": "rsa-v1_5-sha256"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "60e052a9-629b-4e48-ae58-52642e951c9c"
      }
    }
  }
}
