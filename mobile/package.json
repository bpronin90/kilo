{
  "name": "mobile",
  "version": "0.52.1",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "android:tunnel": "expo start --tunnel --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "publish:android": "eas update --platform android --channel production --private-key-path \"${EXPO_OTA_PRIVATE_KEY_PATH:?set EXPO_OTA_PRIVATE_KEY_PATH to the OTA private key path}\"",
    "publish:android:preview": "eas update --platform android --channel preview --private-key-path \"${EXPO_OTA_PRIVATE_KEY_PATH:?set EXPO_OTA_PRIVATE_KEY_PATH to the OTA private key path}\"",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "moduleNameMapper": {
      "@react-native-async-storage/async-storage": "@react-native-async-storage/async-storage/jest/async-storage-mock"
    }
  },
  "private": true
}
